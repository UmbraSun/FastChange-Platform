<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UI.ViewModels"
             x:Class="UI.Views.RegisterPage"
             x:DataType="vm:RegisterViewModel"
             BackgroundColor="{DynamicResource ExchangeBg}"
             NavigationPage.HasNavigationBar="False">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0" Margin="0,10,0,0">
            <Label Text="FastChange" TextColor="{DynamicResource ExchangeGreen}" FontSize="22" FontAttributes="Bold"/>
        </HorizontalStackLayout>

        <!-- Main Form -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="16" MaximumWidthRequest="400">
            <Label Text="Create your account" TextColor="{DynamicResource ExchangeText}" FontSize="26" FontAttributes="Bold"/>
            <Label Text="Register to start trading." TextColor="{DynamicResource ExchangeMuted}" FontSize="14"/>

            <VerticalStackLayout Spacing="6">
                <Label Text="EMAIL ADDRESS" TextColor="{DynamicResource ExchangeMuted}" FontSize="11" FontAttributes="Bold"/>
                <Entry Text="{Binding Email}" Placeholder="you@example.com" Keyboard="Email" 
                       TextColor="{DynamicResource ExchangeText}" 
                       BackgroundColor="{DynamicResource ExchangeCard}"
                       PlaceholderColor="{DynamicResource ExchangeMuted}"
                       FontSize="14"
                       HeightRequest="45"/>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="6">
                <Label Text="PASSWORD" TextColor="{DynamicResource ExchangeMuted}" FontSize="11" FontAttributes="Bold"/>
                <Entry Text="{Binding Password}" Placeholder="••••••••" IsPassword="True" 
                       TextColor="{DynamicResource ExchangeText}" 
                       BackgroundColor="{DynamicResource ExchangeCard}"
                       PlaceholderColor="{DynamicResource ExchangeMuted}"
                       FontSize="14"
                       HeightRequest="45"/>
            </VerticalStackLayout>

            <ActivityIndicator IsRunning="{Binding IsBusy}" Color="{DynamicResource ExchangeGreen}" HeightRequest="30"/>

            <Button Text="Sign Up" 
                    Command="{Binding RegisterAsyncCommand}"
                    BackgroundColor="{DynamicResource ExchangeGreen}" 
                    TextColor="{DynamicResource ExchangeBg}" 
                    FontAttributes="Bold" 
                    HeightRequest="50"
                    CornerRadius="12"
                    FontSize="16"/>
        </VerticalStackLayout>

        <!-- Footer -->
        <Label Grid.Row="2" Text="By creating an account, you agree to our Terms." TextColor="{DynamicResource ExchangeMuted}" FontSize="11" HorizontalTextAlignment="Center"/>
    </Grid>

</ContentPage>
