<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Core.MainPage"
             BackgroundColor="{DynamicResource ExchangeBg}">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20">
        <!-- Header -->
        <HorizontalStackLayout Grid.Row="0" Margin="0,10,0,0">
            <Label Text="FastChange" TextColor="{DynamicResource ExchangeGreen}" FontSize="22" FontAttributes="Bold"/>
        </HorizontalStackLayout>

        <!-- Main Content -->
        <VerticalStackLayout Grid.Row="1" VerticalOptions="Center" Spacing="20" MaximumWidthRequest="400">
            <Label Text="Welcome to FastChange" TextColor="{DynamicResource ExchangeText}" FontSize="26" FontAttributes="Bold"/>
            <Label Text="The next-generation cryptocurrency exchange platform" TextColor="{DynamicResource ExchangeMuted}" FontSize="14"/>

<Border BackgroundColor="{DynamicResource ExchangeCard}" StrokeThickness="0" StrokeShape="RoundRectangle 12" Padding="20">
                <VerticalStackLayout Spacing="10">
                    <Label Text="Secure &amp; Reliable" TextColor="{DynamicResource ExchangeText}" FontSize="16" FontAttributes="Bold"/>
                    <Label Text="Advanced security protocols and multi-signature wallets to keep your assets safe." TextColor="{DynamicResource ExchangeMuted}" FontSize="12"/>
                </VerticalStackLayout>
            </Border>

            <Button x:Name="CounterBtn" Text="Get Started" 
                    Clicked="OnCounterClicked"
                    BackgroundColor="{DynamicResource ExchangeGreen}" 
                    TextColor="{DynamicResource ExchangeBg}" 
                    FontAttributes="Bold" 
                    HeightRequest="50"
                    CornerRadius="12"
                    FontSize="16"/>
        </VerticalStackLayout>

        <!-- Footer -->
        <Label Grid.Row="2" Text="Already have an account? Sign in" TextColor="{DynamicResource ExchangeMuted}" FontSize="12" HorizontalTextAlignment="Center"/>
    </Grid>

</ContentPage>
